<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Schenker Control Tray"
    Manufacturer="gwd"
    Version="$(var.ProductVersion)"
    UpgradeCode="c6c7f47d-284e-42c2-9c30-c1511835f078"
    Language="1033"
    InstallerVersion="500"
    Scope="perMachine">

    <SummaryInformation Description="Schenker Control Tray" Manufacturer="gwd" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SchenkerControlTray" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Schenker Control Tray" />
    </StandardDirectory>

    <Icon Id="AppIcon" SourceFile="$(var.PublishDir)\SchenkerControlTray.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <Feature Id="MainFeature" Title="Schenker Control Tray" Level="1">
      <ComponentRef Id="cmpExe" />
      <ComponentRef Id="cmpDll" />
      <ComponentRef Id="cmpDeps" />
      <ComponentRef Id="cmpRuntimeConfig" />
      <ComponentRef Id="cmpDataVisualization" />
      <ComponentRef Id="cmpOleDb" />
      <ComponentRef Id="cmpShortcut" />
    </Feature>
  </Package>

  <Fragment>
    <Component Id="cmpExe" Directory="INSTALLFOLDER" Guid="*">
      <File Id="filExe" Source="$(var.PublishDir)\SchenkerControlTray.exe" KeyPath="yes" />
    </Component>

    <Component Id="cmpDll" Directory="INSTALLFOLDER" Guid="*">
      <File Id="filDll" Source="$(var.PublishDir)\SchenkerControlTray.dll" KeyPath="yes" />
    </Component>

    <Component Id="cmpDeps" Directory="INSTALLFOLDER" Guid="*">
      <File Id="filDeps" Source="$(var.PublishDir)\SchenkerControlTray.deps.json" KeyPath="yes" />
    </Component>

    <Component Id="cmpRuntimeConfig" Directory="INSTALLFOLDER" Guid="*">
      <File Id="filRuntimeConfig" Source="$(var.PublishDir)\SchenkerControlTray.runtimeconfig.json" KeyPath="yes" />
    </Component>

    <Component Id="cmpDataVisualization" Directory="INSTALLFOLDER" Guid="*">
      <File Id="filDataVisualization" Source="$(var.PublishDir)\System.Windows.Forms.DataVisualization.dll" KeyPath="yes" />
    </Component>

    <Component Id="cmpOleDb" Directory="INSTALLFOLDER" Guid="*">
      <File Id="filOleDb" Source="$(var.PublishDir)\System.Data.OleDb.dll" KeyPath="yes" />
    </Component>

    <Component Id="cmpShortcut" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut
        Id="ApplicationStartMenuShortcut"
        Name="Schenker Control Tray"
        Description="Tray app for SCHENKER / XMG Control Center systems"
        Target="[INSTALLFOLDER]SchenkerControlTray.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <Shortcut
        Id="ApplicationUninstallShortcut"
        Name="Uninstall Schenker Control Tray"
        Description="Remove Schenker Control Tray"
        Target="[System64Folder]msiexec.exe"
        Arguments="/x [ProductCode]" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\gwd\SchenkerControlTray" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
