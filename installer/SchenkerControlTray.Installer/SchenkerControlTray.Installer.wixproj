<Project Sdk="WixToolset.Sdk/4.0.5">

  <PropertyGroup>
    <OutputType>Package</OutputType>
    <InstallerPlatform>x64</InstallerPlatform>
    <ProductVersion Condition="'$(ProductVersion)' == ''">1.0.0</ProductVersion>
    <DefineConstants>PublishDir=$(MSBuildThisFileDirectory)..\..\SchenkerControlTray\bin\Release\net8.0-windows\win-x64\publish;ProductVersion=$(ProductVersion)</DefineConstants>
  </PropertyGroup>

</Project>
